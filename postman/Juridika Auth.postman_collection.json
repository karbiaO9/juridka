        {
          "name": "CI Avocat Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Avocat login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Login returns token', function () {",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('avocatToken', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
