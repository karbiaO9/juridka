    {
      "name": "Client Auth",
      "item": [
        {
          "name": "Client Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.pendingId) pm.collectionVariables.set('clientPendingId', json.pendingId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{clientPassword}}\",\n  \"fullName\": \"Client Test\",\n  \"phone\": \"+21620000001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/client/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "client",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Client Verify Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('clientToken', json.token);",
                  "  if (json.user && json.user._id) pm.collectionVariables.set('clientApprovedId', json.user._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pendingId\": \"{{clientPendingId}}\",\n  \"otp\": \"{{clientOtp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/client/verify-email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "client",
                "verify-email"
              ]
            }
          }
        },
        {
          "name": "Client Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('clientToken', json.token);",
                  "}"
